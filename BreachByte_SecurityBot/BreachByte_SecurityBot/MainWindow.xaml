       |       |__] |  \ |___ |  | |___ |  | |__]   |    |  |___         |
       |                                                                 |
       |       ____ ____ ____ _  _ ____ _ ___ _   _    ___  ____ ___     |
       |       [__  |___ |    |  | |__/ |  |   \_/     |__] |  |  |      |
       |       ___] |___ |___ |__| |  \ |  |    |      |__] |__|  |      |
       |                                                                 |
       |                                                                 |
       '---------------------------------------------------------------'
            </TextBlock>

            <TextBlock HorizontalAlignment="Center" Foreground="#FF0ADCDC" FontFamily="Consolas" FontSize="8.5" xml:space="preserve" Margin="0,5,0,0">
