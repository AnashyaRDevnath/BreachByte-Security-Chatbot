<Window x:Class="BreachByte_SecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BreachByte Security Terminal" Height="750" Width="1200" Background="#0F0F13">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,20" Padding="15">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A1A24" Offset="0.0"/>
                        <GradientStop Color="#0F0F13" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF0ADCDC" Offset="0.0"/>
                        <GradientStop Color="DarkMagenta" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1.5</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="#FF0ADCDC" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Ellipse Width="8" Height="8" Fill="#39FF14" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#39FF14" BlurRadius="10" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="Cybersecurity Awareness" Foreground="#39FF14" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock HorizontalAlignment="Center" Foreground="#FF0ADCDC" FontFamily="Consolas" FontSize="10" xml:space="preserve">
                              ------------------------
                            .                          .
                           /                            \
                          /                              \
                         |                                |
                         |                                |
                         |                                |
           --------------------------------------------------------- 
        .                                                               .
       |       ___  ____ ____ ____ ____ _  _ ___  _   _ ___ ____         |
       |       |__] |__/ |___ |__| |    |__| |__]  \_/   |  |___         |
       |       |__] |  \ |___ |  | |___ |  | |__]   |    |  |___         |
       |                                                                 |
       |       ____ ____ ____ _  _ ____ _ ___ _   _    ___  ____ ___     |
       |       [__  |___ |    |  | |__/ |  |   \_/     |__] |  |  |      |
       |       ___] |___ |___ |__| |  \ |  |    |      |__] |__|  |      |
       |                                                                 |
       |                                                                 |
       '---------------------------------------------------------------'
                    </TextBlock>

                    <TextBlock HorizontalAlignment="Center" Foreground="White" Opacity="0.8" FontFamily="Consolas" FontSize="8.5" xml:space="preserve" Margin="0,10,0,0">
,--.,--.              ,--.                                ,--.                                   ,--.        ,--.                                     ,-.   
|  ||  |,--,--,--.    |  ,---.  ,---. ,--.--. ,---.     ,-'  '-. ,---.      ,--,--. ,---.  ,---. `--' ,---.,-'  '-.    ,--. ,--.,---. ,--.,--.    .--.'. \  
|  |`-' |        |    |  .-.  || .-. :|  .--'| .-. :    '-.  .-'| .-. |    ' ,-.  |(  .-' (  .-' ,--.(  .-''-.  .-'     \  '  /| .-. ||  ||  |    '--' |  | 
|  |    |  |  |  |    |  | |  |\   --.|  |   \   --.      |  |  ' '-' '    \ '-'  |.-'  `).-'  `)|  |.-'  `) |  |        \   ' ' '-' ''  ''  '    .--. |  | 
`--'    `--`--`--'    `--' `--' `----'`--'    `----'      `--'   `---'      `--`--'`----' `----' `--'`----'  `--'      .-'  /   `---'  `----'     '--'.' /  
                                                                                                                       `---'                          `-'
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#181820" CornerRadius="10" Margin="0,0,0,20" BorderBrush="#303040" BorderThickness="1" Padding="20">
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatHistoryPanel" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E28" CornerRadius="8" Margin="0,0,15,0" BorderBrush="#404055" BorderThickness="1">
                    <TextBox x:Name="UserInputBox" Background="Transparent" Foreground="White" BorderThickness="0" Padding="15" FontSize="14" VerticalContentAlignment="Center" KeyDown="UserInputBox_KeyDown"/>
                </Border>

                <Button x:Name="SendButton" Grid.Column="1" Width="110" Foreground="White" FontWeight="Bold" FontSize="15" Cursor="Hand" Click="SendButton_Click" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="DarkMagenta" Offset="0.0"/>
                            <GradientStop Color="#8B008B" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="SEND ►" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>

        <Border Grid.Column="1" Background="#181820" CornerRadius="10" BorderBrush="#303040" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="[ SYSTEM TASKS ]" FontSize="18" FontFamily="Consolas" FontWeight="Bold" Foreground="#FF0ADCDC" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <DataGrid x:Name="TasksDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="#1E1E28" Foreground="White" BorderBrush="#404055" BorderThickness="1" RowBackground="#1A1A24" AlternatingRowBackground="#181820" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding task_id}" IsReadOnly="True" Width="40"/>
                        <DataGridTextColumn Header="Task" Binding="{Binding title}" Width="150"/>
                        <DataGridCheckBoxColumn Header="Done" Binding="{Binding is_completed}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="BtnRefreshTasks" Content="REFRESH" Width="100" Height="35" Margin="0,0,10,0" Foreground="Black" FontWeight="Bold" Background="#39FF14" BorderThickness="0" Click="BtnRefreshTasks_Click"/>
                    <Button x:Name="BtnAddTask" Content="NEW TASK +" Width="120" Height="35" Foreground="White" FontWeight="Bold" Background="DarkMagenta" BorderThickness="0" Click="BtnAddTask_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>