<Window x:Class="BreachByte_SecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BreachByte Security Terminal" Height="750" Width="1200" Background="#0F0F13">
    <Window.Resources>
        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="DarkMagenta"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="neonBorder" 
                            BorderBrush="#FF0ADCDC" 
                            BorderThickness="1" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="neonBorder" Property="Background" Value="#330ADCDC"/>
                                <Setter TargetName="neonBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="neonBorder" Property="Background" Value="#FF0ADCDC"/>
                                <Setter Property="Foreground" Value="#0D1117"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1A1A24" BorderBrush="#FF0ADCDC" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnNavQuiz" Content="Launch Cyber Quiz Game" Margin="0,0,20,0" Style="{StaticResource NeonButtonStyle}" Click="BtnNavQuiz_Click"/>
                <Button x:Name="BtnNavTopics" Content="What can I ask?" Margin="0,0,20,0" Style="{StaticResource NeonButtonStyle}" Click="BtnNavTopics_Click"/>
                <Button x:Name="BtnNavLog" Content="System History" Style="{StaticResource NeonButtonStyle}" Click="BtnNavLog_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,20" Padding="15">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A1A24" Offset="0.0"/>
                        <GradientStop Color="#0F0F13" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF0ADCDC" Offset="0.0"/>
                        <GradientStop Color="DarkMagenta" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1.5</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="#FF0ADCDC" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Ellipse Width="8" Height="8" Fill="#39FF14" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#39FF14" BlurRadius="10" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="Cybersecurity Awareness" Foreground="#39FF14" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock HorizontalAlignment="Center" Foreground="#FF0ADCDC" FontFamily="Consolas" FontSize="10" xml:space="preserve">
                              ------------------------
                            .                          .
                           /                            \
                          /                              \
                         |                                |
                         |                                |
                         |                                |
            --------------------------------------------------------- 
        .                                                              .
       |       ___  ____ ____ ____ ____ _  _ ___  _   _ ___ ____         |
       |       |__] |__/ |___ |__| |    |__| |__]  \_/   |  |___         |
       |       |__] |  \ |___ |  | |___ |  | |__]   |    |  |___         |
       |                                                                 |
       |       ____ ____ ____ _  _ ____ _ ___ _   _    ___  ____ ___     |
       |       [__  |___ |    |  | |__/ |  |   \_/     |__] |  |  |      |
       |       ___] |___ |___ |__| |  \ |  |    |      |__] |__|  |      |
       |                                                                 |
       |                                                                 |
       '---------------------------------------------------------------'
                    </TextBlock>

                    <TextBlock HorizontalAlignment="Center" Foreground="White" Opacity="0.8" FontFamily="Consolas" FontSize="8.5" xml:space="preserve" Margin="0,10,0,0">
,--.,--.              ,--.                                ,--.                                   ,--.        ,--.                                     ,-.   
|  ||  |,--,--,--.    |  ,---.  ,---. ,--.--. ,---.     ,-'  '-. ,---.      ,--,--. ,---.  ,---. `--' ,---.,-'  '-.    ,--. ,--.,---. ,--.,--.    .--.'. \  
|  |`-' |        |    |  .-.  || .-. :|  .--'| .-. :    '-.  .-'| .-. |    ' ,-.  |(  .-' (  .-' ,--.(  .-''-.  .-'     \  '  /| .-. ||  ||  |    '--' |  | 
|  |    |  |  |  |    |  | |  |\   --.|  |   \   --.      |  |  ' '-' '    \ '-'  |.-'  `).-'  `)|  |.-'  `) |  |        \   ' ' '-' ''  ''  '    .--. |  | 
`--'    `--`--`--'    `--' `--' `----'`--'    `----'      `--'   `---'      `--`--'`----' `----' `--'`----'  `--'      .-'  /   `---'  `----'     '--'.' /  
                                                                                                                      `---'                          `-'
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#181820" CornerRadius="10" Margin="0,0,0,20" BorderBrush="#303040" BorderThickness="1" Padding="20">
                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatHistoryPanel" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E28" CornerRadius="8" Margin="0,0,15,0" BorderBrush="#404055" BorderThickness="1">
                    <TextBox x:Name="UserInputBox" Background="Transparent" Foreground="White" BorderThickness="0" Padding="15" FontSize="14" VerticalContentAlignment="Center" KeyDown="UserInputBox_KeyDown"/>
                </Border>

                <Button x:Name="SendButton" Grid.Column="1" Width="110" Foreground="White" FontWeight="Bold" FontSize="15" Cursor="Hand" Click="SendButton_Click" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="DarkMagenta" Offset="0.0"/>
                            <GradientStop Color="#8B008B" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="SEND ►" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Background="#0D1117" BorderBrush="#FF0ADCDC" BorderThickness="1" CornerRadius="8" Margin="10,0,0,0" Padding="15">
            <Border.Effect>
                <DropShadowEffect Color="#FF0ADCDC" BlurRadius="15" ShadowDepth="0" Opacity="0.4" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="--SYSTEM TASKS--" FontSize="18" FontFamily="Consolas" FontWeight="Bold" Foreground="#FF0ADCDC" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <DataGrid x:Name="TasksDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="#1E1E28" Foreground="#39FF14" BorderBrush="#404055" BorderThickness="1" 
                          RowBackground="#1A1A24" AlternatingRowBackground="#181820" HeadersVisibility="Column">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1A1A24"/>
                            <Setter Property="Foreground" Value="#FF0ADCDC"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,5,10,5"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#404055"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding task_id}" IsReadOnly="True" Width="40"/>
                        <DataGridTextColumn Header="Task" Binding="{Binding title}" Width="150"/>
                        <DataGridCheckBoxColumn Header="Done" Binding="{Binding is_completed}" Width="50"/>
                        <DataGridTextColumn Header="Reminder" Binding="{Binding reminder_date, StringFormat=\{0:dd/MM/yyyy\}}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="BtnRefreshTasks" Content="REFRESH" Width="90" Height="35" Margin="0,0,10,0" Style="{StaticResource NeonButtonStyle}" Click="BtnRefreshTasks_Click"/>
                    <Button x:Name="BtnToggleStatus" Content="DONE" Width="110" Height="35" Margin="0,0,10,0" Style="{StaticResource NeonButtonStyle}" Click="BtnToggleStatus_Click"/>
                    <Button x:Name="BtnDeleteTask" Content="DELETE" Width="90" Height="35" Margin="0,0,10,0" Style="{StaticResource NeonButtonStyle}" Click="BtnDeleteTask_Click"/>
                    <Button x:Name="BtnAddTask" Content="NEW TASK +" Width="110" Height="35" Style="{StaticResource NeonButtonStyle}" Click="BtnAddTask_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>