<Window x:Class="BreachByte_SecurityBot.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Training Simulator" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" Background="#1E1E2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title & Score -->
            <RowDefinition Height="*"/>
            <!-- Question Text -->
            <RowDefinition Height="Auto"/>
            <!-- Feedback Text -->
            <RowDefinition Height="Auto"/>
            <!-- Answer Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="[ TRAINING SIMULATOR ]" Foreground="#00FFCC" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left"/>
            <TextBlock x:Name="ScoreText" Text="Score: 0" Foreground="White" FontSize="18" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Question Display -->
        <Border Grid.Row="1" Background="#2A2A3C" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <TextBlock x:Name="QuestionTextBlock" Text="Loading question..." Foreground="White" FontSize="16" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
        </Border>

        <!-- Feedback Display (Hidden initially) -->
        <TextBlock x:Name="FeedbackTextBlock" Grid.Row="2" Text="" Foreground="#39FF14" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20" TextAlignment="Center" Visibility="Collapsed"/>

        <!-- Answer Buttons Panel -->
        <StackPanel x:Name="AnswersPanel" Grid.Row="3" Orientation="Vertical">
            <!-- Buttons dynamically generated by C# -->
        </StackPanel>

        <!-- Next Question Button (Hidden initially) -->
        <Button x:Name="NextButton" Grid.Row="3" Content="NEXT QUESTION ►" Foreground="White" Background="DarkMagenta" FontWeight="Bold" Height="40" Visibility="Collapsed" Click="NextButton_Click"/>
    </Grid>
</Window>
